# Tlalpohua: normalizacion conservadora de finales de linea y binarios.
* text=auto
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf
*.sh text eol=lf
*.c text
*.h text
*.cpp text
*.hpp text
*.cmake text
CMakeLists.txt text
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.exe binary
*.dll binary
*.ixiptlah binary
*.tile binary
*.pdf binary
*.zip binary
*.7z binary
